              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/ApproveStaffDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/ApproveStaffDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
