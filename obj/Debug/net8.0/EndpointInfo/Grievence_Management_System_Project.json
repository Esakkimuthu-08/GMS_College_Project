{
  "openapi": "3.0.1",
  "info": {
    "title": "Grievence_Management_System_Project",
    "version": "1.0"
  },
  "paths": {
    "/api/Auth/staffSignUp": {
      "post": {
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StaffSignUpRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/StaffSignUpRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/StaffSignUpRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Auth/getAllStaffRequest": {
      "get": {
        "tags": [
          "Auth"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Staff/createStaff": {
      "post": {
        "tags": [
          "Staff"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StaffRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/StaffRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/StaffRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Staff/getAllStaffs": {
      "get": {
        "tags": [
          "Staff"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Student/createstudent": {
      "post": {
        "tags": [
          "Student"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StudentSignUpRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/StudentSignUpRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/StudentSignUpRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "StaffRequest": {
        "required": [
          "email",
          "name",
          "phoneNumber",
          "staffCode"
        ],
        "type": "object",
        "properties": {
          "staffCode": {
            "minLength": 1,
            "type": "string"
          },
          "name": {
            "minLength": 1,
            "type": "string"
          },
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "phoneNumber": {
            "minLength": 1,
            "pattern": "^\\d{10}$",
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "StaffSignUpRequest": {
        "required": [
          "email",
          "name",
          "passwordHash"
        ],
        "type": "object",
        "properties": {
          "name": {
            "minLength": 1,
            "type": "string"
          },
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "passwordHash": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "StudentSignUpRequest": {
        "required": [
          "email",
          "name",
          "passwordHash",
          "rollNo",
          "staffCode"
        ],
        "type": "object",
        "properties": {
          "rollNo": {
            "minLength": 1,
            "type": "string"
          },
          "name": {
            "minLength": 1,
            "type": "string"
          },
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "passwordHash": {
            "minLength": 1,
            "type": "string"
          },
          "staffCode": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  }
}