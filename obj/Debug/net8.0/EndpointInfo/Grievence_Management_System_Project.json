  "components": {
    "schemas": {
      "ApproveStaffDto": {
        "required": [
          "phoneNumber",
          "role",
          "signupRequestId",
          "staffCode"
        ],
        "type": "object",
        "properties": {
          "signupRequestId": {
            "type": "integer",
            "format": "int32"
          },
          "role": {
            "$ref": "#/components/schemas/RoleEnum"
          },
          "staffCode": {
            "minLength": 1,
            "type": "string"
          },
          "phoneNumber": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "ApproveStudentDto": {
        "required": [
          "phoneNumber",
          "studentSignUpId"
        ],
        "type": "object",
        "properties": {
          "studentSignUpId": {
            "type": "integer",
            "format": "int32"
          },
          "phoneNumber": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "RoleEnum": {
        "enum": [
          1,
          2,
          3,
          4,
          5,
          6
        ],
        "type": "integer",
        "format": "int32"
      },
      "StaffRequest": {
        "required": [
          "email",
          "name",
          "phoneNumber",
          "staffCode"
        ],
        "type": "object",
        "properties": {
          "staffCode": {
            "minLength": 1,
            "type": "string"
          },
          "name": {
            "minLength": 1,
            "type": "string"
          },
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "phoneNumber": {
            "minLength": 1,
            "pattern": "^\\d{10}$",
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "StaffSignUpRequest": {
        "required": [
          "email",
          "name",
          "passwordHash"
        ],
        "type": "object",
        "properties": {
          "name": {
            "minLength": 1,
            "type": "string"
          },
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "passwordHash": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "StudentSignUpRequest": {
        "required": [
          "email",
          "name",
          "passwordHash",
          "rollNo",
          "staffCode"
        ],
        "type": "object",
        "properties": {
          "rollNo": {
            "minLength": 1,
            "type": "string"
          },
          "name": {
            "minLength": 1,
            "type": "string"
          },
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "passwordHash": {
            "minLength": 1,
            "type": "string"
          },
          "staffCode": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  }
